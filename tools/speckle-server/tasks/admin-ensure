#!/usr/bin/env bash
# Create admin account if it doesn't exist yet

REG_JSON=$(printf '{"email":"%s","password":"%s","name":"%s"}' "$SPECKLE_ADMIN_EMAIL" "$SPECKLE_ADMIN_PASSWORD" "$SPECKLE_ADMIN_NAME")
REG_RESP=$(curl -sf -H 'Content-Type: application/json' \
  -d "$REG_JSON" \
  "http://127.0.0.1:3000/auth/local/register?challenge=auto-setup" 2>&1 || true)

if echo "$REG_RESP" | grep -q "access_code"; then
  echo "  Admin account created: $SPECKLE_ADMIN_EMAIL"
else
  echo "  Admin account already exists: $SPECKLE_ADMIN_EMAIL"
fi
