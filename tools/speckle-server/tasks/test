#!/usr/bin/env bash
PASS=0; FAIL=0

ok()   { echo "  $1"; PASS=$((PASS + 1)); }
fail() { echo "  FAIL: $1"; FAIL=$((FAIL + 1)); }

echo "Infra:"
pg_ctl -D "$PGDATA" status >/dev/null 2>&1 && ok "Postgres" || fail "Postgres"
redis-cli ping >/dev/null 2>&1 && ok "Redis" || fail "Redis"
curl -sf http://127.0.0.1:9000/minio/health/live >/dev/null 2>&1 && ok "MinIO" || fail "MinIO"

echo ""
echo "Services:"
API_RESP=$(curl -sf -H "Content-Type: application/json" -d '{"query":"{ serverInfo { version } }"}' http://127.0.0.1:3000/graphql 2>&1 || true)
echo "$API_RESP" | grep -q "version" && ok "API server ($(echo "$API_RESP" | grep -o '"version":"[^"]*"' | cut -d'"' -f4))" || fail "API server"
curl -sf -o /dev/null http://127.0.0.1:8080 && ok "Frontend" || fail "Frontend"

echo ""
echo "Auth:"
LOGIN_RESP=$(curl -s -H "Content-Type: application/json" \
  -d '{"email":"'"$SPECKLE_ADMIN_EMAIL"'","password":"'"$SPECKLE_ADMIN_PASSWORD"'"}' \
  "http://127.0.0.1:3000/auth/local/login?challenge=test" 2>&1 || true)
CODE=$(echo "$LOGIN_RESP" | grep -o 'access_code=[^&"]*' | head -1 | cut -d= -f2)

if [ -n "$CODE" ]; then
  TOKEN_RESP=$(curl -sf -H "Content-Type: application/json" \
    -d '{"appId":"spklwebapp","appSecret":"spklwebapp","accessCode":"'"$CODE"'","challenge":"test"}' \
    http://127.0.0.1:3000/auth/token 2>&1 || true)
  TOKEN=$(echo "$TOKEN_RESP" | grep -o '"token":"[^"]*"' | cut -d'"' -f4)
fi

if [ -n "$TOKEN" ]; then
  ok "Login"
  USER_RESP=$(curl -sf -H "Content-Type: application/json" -H "Authorization: Bearer $TOKEN" \
    -d '{"query":"{ activeUser { name role } }"}' http://127.0.0.1:3000/graphql 2>&1 || true)
  echo "$USER_RESP" | grep -q "server:admin" && ok "Admin role" || fail "Admin role"
else
  fail "Login"
fi

echo ""
echo "Logs:"
SRV_ERR=$(pitchfork logs speckle-api --raw --no-pager 2>/dev/null | grep -c '"@l":"Error"') || SRV_ERR=0
FE_ERR=$(pitchfork logs speckle-frontend --raw --no-pager 2>/dev/null | grep -c '"@l":"Error"') || FE_ERR=0
echo "  Server errors:   $SRV_ERR"
echo "  Frontend errors: $FE_ERR"

echo ""
echo "══════════════════════════════════════════════════"
if [ "$FAIL" -eq 0 ]; then
  echo "  All $PASS tests passed"
else
  echo "  $PASS passed, $FAIL failed"
fi
echo "══════════════════════════════════════════════════"
[ "$FAIL" -eq 0 ]
