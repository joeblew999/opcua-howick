#!/usr/bin/env bash
set -euo pipefail

echo "══════════════════════════════════════════════════"
echo "  Speckle Server — First Time Setup"
echo "══════════════════════════════════════════════════"

if [ ! -f "$SPECKLE_ROOT/.env" ]; then
  echo "Creating .env from .env.example..."
  cp "$SPECKLE_ROOT/.env.example" "$SPECKLE_ROOT/.env"
fi

mkdir -p "$SPECKLE_LOGS"

if [ -d "$SPECKLE_SRC" ]; then
  echo "Already cloned. Checking out $SPECKLE_VERSION..."
  cd "$SPECKLE_SRC" && git fetch --tags && git checkout "$SPECKLE_VERSION"
else
  git clone --branch "$SPECKLE_VERSION" --depth 1 https://github.com/specklesystems/speckle-server.git "$SPECKLE_SRC"
fi
echo "Speckle server @ $SPECKLE_VERSION"

cd "$SPECKLE_SRC"
corepack enable
yarn 2>&1 | tee "$SPECKLE_LOGS/install.log"
yarn build:public 2>&1 | tee -a "$SPECKLE_LOGS/install.log"

echo ""
echo "══════════════════════════════════════════════════"
echo "  Building for production..."
echo "══════════════════════════════════════════════════"
NODE_ENV=production yarn build 2>&1 | tee "$SPECKLE_LOGS/build.log"

mkdir -p "$SPECKLE_DATA" "$MINIO_DATA"
if [ ! -d "$PGDATA" ]; then
  echo "Initializing Postgres..."
  initdb -D "$PGDATA" --username=speckle --auth=trust
  echo "port = 5432" >> "$PGDATA/postgresql.conf"
fi

echo ""
echo "Setup complete! Run: mise run start"
