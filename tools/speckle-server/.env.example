# Speckle server — local native config
# All services on localhost (no Docker networking)

CANONICAL_URL=http://127.0.0.1:3000
FRONTEND_ORIGIN=http://127.0.0.1:8080

# Postgres (native via mise)
POSTGRES_URL=localhost
POSTGRES_USER=speckle
POSTGRES_PASSWORD=speckle
POSTGRES_DB=speckle
PG_CONNECTION_STRING=postgres://speckle@localhost:5432/speckle
FILEIMPORT_QUEUE_POSTGRES_URL=postgresql://speckle@localhost:5432/speckle

# Redis (native via mise)
REDIS_URL=redis://127.0.0.1:6379

# MinIO / S3 (native via mise)
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=speckle-server
S3_CREATE_BUCKET=true

# Auth
SESSION_SECRET=opcua-howick-local-dev-secret
STRATEGY_LOCAL=true

# Admin account (created automatically by mise run setup)
SPECKLE_ADMIN_NAME=Admin
SPECKLE_ADMIN_EMAIL=admin@howick.local
SPECKLE_ADMIN_PASSWORD=howick2024

# Services (all on localhost when running from source)
PRIVATE_OBJECTS_SERVER_URL=http://127.0.0.1:3000
PREVIEW_SERVICE_USE_PRIVATE_OBJECTS_SERVER_URL=true
PREVIEW_SERVICE_REDIS_URL=redis://127.0.0.1:6379
FILEIMPORT_SERVICE_USE_PRIVATE_OBJECTS_SERVER_URL=true
FILEIMPORT_SERVICE_REDIS_URL=redis://127.0.0.1:6379
OBJECTS_SERVER_URL=http://127.0.0.1:3000
SPECKLE_SERVER_URL=http://127.0.0.1:3000

# Frontend (Nuxt)
NUXT_PUBLIC_SERVER_NAME=opcua-howick-local
NUXT_PUBLIC_API_ORIGIN=http://127.0.0.1:3000
NUXT_PUBLIC_BASE_URL=http://127.0.0.1:8080
NUXT_PUBLIC_BACKEND_API_ORIGIN=http://127.0.0.1:3000
NUXT_PUBLIC_LOG_LEVEL=warn
NUXT_REDIS_URL=redis://127.0.0.1:6379

# Misc
LOG_LEVEL=info
FILE_SIZE_LIMIT_MB=100
EMAIL_FROM=no-reply@localhost
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=false
FF_NEXT_GEN_FILE_IMPORTER_ENABLED=true
